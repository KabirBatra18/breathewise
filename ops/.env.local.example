# Local development — Postgres installed via Homebrew.
# On Vercel: leave DATABASE_URL unset and let Vercel Postgres inject
# POSTGRES_URL / POSTGRES_URL_NON_POOLING automatically.
DATABASE_URL=postgresql://YOUR_OS_USER@localhost:5432/breathewise_ops

# HMAC secret for session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=replace_with_32_random_bytes_base64

# First owner — created on `pnpm db:seed` if no row exists for this username.
SEED_OWNER_USERNAME=Kabir
SEED_OWNER_PASSWORD=101510
SEED_OWNER_FULLNAME=Kabir
