# Local Postgres, installed via Homebrew (no password for local connection).
# Change to your Supabase URL for deployment.
DATABASE_URL=postgresql://YOUR_OS_USER@localhost:5432/breathewise_ops

# HMAC secret for session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=replace_with_32_random_bytes_base64

# First owner account — created on `pnpm db:seed` if the user table is empty.
# Change the password on first login.
SEED_OWNER_USERNAME=Kabir
SEED_OWNER_PASSWORD=101510
SEED_OWNER_FULLNAME=Kabir
