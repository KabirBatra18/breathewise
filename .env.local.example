# Supabase (from Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_SECRET_KEY

# Direct Postgres connection string for Drizzle (Project Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Seed credentials for the first OWNER account
SEED_OWNER_EMAIL=kabirbatra220@gmail.com
SEED_OWNER_INITIAL_PASSWORD=CHANGE_ON_FIRST_LOGIN

# TOTP secret encryption key (32 bytes, base64). Auto-generated on first run if absent.
TOTP_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTES

# Public app URL (used for TOTP issuer string and PDF file URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
